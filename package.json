{
  "name": "nodir-hdd-fixer",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/dev.js",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "dev:all": "bash scripts/start-dev.sh",
    "build": "turbo run build",
    "build:api": "npm run build --workspace=apps/api",
    "build:web": "npm run build --workspace=apps/web",
    "build:shared": "npm run build --workspace=packages/shared",
    "start:api": "node apps/api/dist/main.js",
    "start:web": "npm run start --workspace=apps/web",
    "start:prod": "bash scripts/deploy.sh",
    "start:api:watch": "node restart-server.js",
    "start:api:ai": "node restart-server-with-ai.js",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "test:e2e": "playwright test --config=tests/e2e/playwright.config.ts",
    "test:e2e:ui": "playwright test --config=tests/e2e/playwright.config.ts --ui",
    "test:e2e:headed": "playwright test --config=tests/e2e/playwright.config.ts --headed",
    "test:e2e:report": "playwright show-report",
    "test:regression": "vitest run --config=tests/regression/vitest.config.ts",
    "test:regression:watch": "vitest --config=tests/regression/vitest.config.ts",
    "test:regression:report": "vitest --config=tests/regression/vitest.config.ts --reporter=html",
    "db:migrate": "npm run migration:run --workspace=apps/api",
    "db:seed": "npm run seed --workspace=apps/api",
    "db:init": "npm run db:migrate && npm run db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:dev:up": "docker compose -f docker-compose.dev.yml up -d",
    "docker:dev:down": "docker compose -f docker-compose.dev.yml down",
    "docker:prod:up": "docker compose -f docker-compose.prod.yml up -d",
    "docker:prod:down": "docker compose -f docker-compose.prod.yml down",
    "deploy": "bash scripts/deploy.sh",
    "generate:api": "node scripts/generate-openapi.js",
    "qwen": "node qwen-agent.js",
    "qwen:interactive": "node qwen-agent.js",
    "qwen:max": "node qwen-agent.js -m qwen-max",
    "qwen:plus": "node qwen-agent.js -m qwen-plus",
    "qwen:turbo": "node qwen-agent.js -m qwen-turbo",
    "qwen:coder": "node qwen-agent.js -m qwen-coder",
    "qwen:models": "node qwen-agent.js -l"
  },
  "devDependencies": {
    "turbo": "^2.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.4.2",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "readline": "^1.3.0",
    "socket.io-client": "^4.8.3"
  }
}
