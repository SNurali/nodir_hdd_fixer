# ===========================================
# HDD Fixer - Environment Variables Template
# ===========================================
# Скопируйте этот файл в .env для локальной разработки
# или в .env.production для продакшена
# ===========================================

# ===========================================
# DATABASE (PostgreSQL 16)
# ===========================================
# Локально: DB_HOST=localhost, DB_PORT=5432 (dev) или 5436 (prod)
# Продакшен: DB_HOST=localhost, DB_PORT=5436
DB_HOST=localhost
DB_PORT=5436
DB_USERNAME=hdd_fixer
DB_PASSWORD=hdd_fixer_secret
DB_DATABASE=hdd_fixer_db

# ===========================================
# REDIS 7
# ===========================================
# Локально: REDIS_HOST=localhost, REDIS_PORT=6379 (dev) или 6380 (prod)
# Продакшен: REDIS_HOST=localhost, REDIS_PORT=6380
REDIS_HOST=localhost
REDIS_PORT=6380

# ===========================================
# JWT Authentication
# ===========================================
# Смените на уникальные значения в продакшене!
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# BACKEND API (NestJS)
# ===========================================
APP_PORT=3004
API_BASE_URL=http://localhost:3004
APP_URL=http://localhost:3004/v1
CORS_ORIGINS=http://localhost:3003,https://hdd-fixer.uz

# ===========================================
# FRONTEND WEB (Next.js)
# ===========================================
WEB_PORT=3003
WEB_URL=http://localhost:3003
NEXT_PUBLIC_API_URL=http://localhost:3004/v1

# ===========================================
# Google OAuth (опционально)
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===========================================
# Notifications (опционально)
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

SMS_API_URL=https://notify.eskiz.uz/api
SMS_API_TOKEN=

FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ===========================================
# File Uploads
# ===========================================
UPLOADS_DIR=uploads

# ===========================================
# Environment
# ===========================================
NODE_ENV=development
