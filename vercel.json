{
  "version": 2,
  "builds": [
    {
      "src": "apps/api/api/index.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "apps/api/api/index.ts"
    }
  ],
  "functions": {
    "apps/api/api/index.ts": {
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "env": {
    "NODE_ENV": "production"
  },
  "outputDirectory": "dist"
}
