# ===========================================
# HDD Fixer - Production Environment Template
# ===========================================
# Скопируйте в .env.production и заполните реальными значениями
# НЕ коммитьте этот файл в Git!
# ===========================================

# ===========================================
# DATABASE (PostgreSQL 16)
# ===========================================
# На боевом сервере порты: 5436 (DB), 6380 (Redis)
DB_HOST=localhost
DB_PORT=5436
DB_USERNAME=hdd_fixer
DB_PASSWORD=CHANGE_TO_SECURE_PASSWORD
DB_DATABASE=hdd_fixer_db

# ===========================================
# REDIS 7
# ===========================================
REDIS_HOST=localhost
REDIS_PORT=6380

# ===========================================
# JWT Authentication
# ===========================================
# ОБЯЗАТЕЛЬНО: Смените на уникальные безопасные значения!
JWT_SECRET=GENERATE_SECURE_RANDOM_STRING_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=GENERATE_SECURE_RANDOM_STRING_32_CHARS
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# BACKEND API (NestJS)
# ===========================================
APP_PORT=3004
API_BASE_URL=https://hdd-fixer.uz
APP_URL=https://hdd-fixer.uz/v1
CORS_ORIGINS=http://localhost:3003,https://hdd-fixer.uz,https://www.hdd-fixer.uz

# ===========================================
# FRONTEND WEB (Next.js)
# ===========================================
WEB_PORT=3003
WEB_URL=https://hdd-fixer.uz
# IMPORTANT: This URL must be accessible from the browser (not localhost!)
# For Docker deployment, use the public URL of your API server
NEXT_PUBLIC_API_URL=http://hddfix.uz:3004/v1

# ===========================================
# Google OAuth
# ===========================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ===========================================
# Notifications
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

SMS_API_URL=https://notify.eskiz.uz/api
SMS_API_TOKEN=your-sms-api-token

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# ===========================================
# Telegram Bot (RECOVERY.UZ)
# ===========================================
TELEGRAM_BOT_TOKEN=8759863943:AAHncy4_UyPHiidyTTLp5e2F9bFJCRTYqfI
TELEGRAM_CHAT_ID=-5240393504

# ===========================================
# File Uploads
# ===========================================
UPLOADS_DIR=uploads

# ===========================================
# Environment
# ===========================================
NODE_ENV=production
